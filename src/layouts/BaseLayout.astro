---
const { title = "m3tr0's blog" } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    
    <script is:inline>
        const theme = (() => {
            if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                return localStorage.getItem('theme');
            }
            if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                return 'dark';
            }
            return 'light';
        })();
        document.documentElement.setAttribute('data-theme', theme);
    </script>

    <style is:global>
        :root {
            --bg-color: #FAFAFA; --text-color: #222222; --text-muted: #666666;
            --border-color: #EAEAEA; --link-color: #111111; --link-hover: #777777;
            --btn-bg: transparent; --btn-border: #DDDDDD; --selection-bg: #D1E8FF;
            --quote-border: #CCCCCC; --code-bg: #F0F0F0;
        }
        [data-theme="dark"] {
            --bg-color: #121212; --text-color: #EAEAEA; --text-muted: #999999;
            --border-color: #2A2A2A; --link-color: #FFFFFF; --link-hover: #BBBBBB;
            --btn-bg: transparent; --btn-border: #444444; --selection-bg: #325C8A;
            --quote-border: #444444; --code-bg: #1E1E1E;
        }
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
            background-color: var(--bg-color); color: var(--text-color);
            line-height: 1.7; margin: 0; padding: 0;
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        ::selection { background-color: var(--selection-bg); }
        a { color: var(--link-color); text-decoration: none; transition: color 0.2s ease; }
        a:hover { color: var(--link-hover); }
        
        /* 全域圖片修正，防止跑版 */
        img { max-width: 100%; height: auto; border-radius: 8px; display: block; }
        
        .container { max-width: 760px; margin: 0 auto; padding: 3rem 1.5rem; min-height: 100vh; display: flex; flex-direction: column; }
        
        header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem; margin-bottom: 4rem; }
        .logo { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.02em; }
        nav { display: flex; align-items: center; gap: 1.5rem; font-size: 0.95rem; }
        #theme-toggle { background: var(--btn-bg); color: var(--text-color); border: 1px solid var(--btn-border); padding: 0.4rem 0.75rem; border-radius: 4px; cursor: pointer; font-size: 0.85rem; }
        #theme-toggle:hover { border-color: var(--text-color); }
        
        main { flex: 1; }
        footer { border-top: 1px solid var(--border-color); padding-top: 2rem; margin-top: 4rem; font-size: 0.85rem; color: var(--text-muted); }

        .article-body h2 { font-size: 1.4rem; margin-top: 2.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
        .article-body p { margin-bottom: 1.5rem; }
        .article-body blockquote { border-left: 3px solid var(--quote-border); margin: 1.5rem 0; padding-left: 1rem; color: var(--text-muted); font-style: italic; }
        .article-body code { background-color: var(--code-bg); padding: 0.2rem 0.4rem; border-radius: 3px; font-family: monospace; font-size: 0.9em; }

        @media (max-width: 600px) {
            header { flex-direction: column; align-items: flex-start; gap: 1rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="logo"><a href="/">m3tr0's posts</a></div>
            <nav>
                <a href="/">posts</a>
                <a href="/about">about</a>
                <button id="theme-toggle">toggle theme</button>
            </nav>
        </header>

        <main>
            <slot />
        </main>

        <footer>
            <p>&copy; 2026 m3tr0. Minimalist Blog.</p>
        </footer>
    </div>

    <script>
        const toggleBtn = document.getElementById('theme-toggle');
        const html = document.documentElement;

        function updateButtonText(theme: string | null) {
            if (!toggleBtn) return;
            toggleBtn.textContent = theme === 'dark' ? 'light' : 'dark';
        }

        updateButtonText(html.getAttribute('data-theme') ?? 'light');

        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                const currentTheme = html.getAttribute('data-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                html.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                updateButtonText(newTheme);
            });
        }
    </script>
</body>
</html>
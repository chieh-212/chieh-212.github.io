---
// src/pages/secret.astro
// 這裡故意不套用 BaseLayout，讓它看起來像個獨立的隱密系統
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ACCESS DENIED</title>
</head>
<body>
    <main class="terminal-wrapper">
        <div class="terminal-box">
            <h1 class="warning-text">⚠️ SYSTEM COMPROMISED</h1>
            <p class="hint">你發現了被禁止的秘密區域...</p>
            
            <div class="flag-box">
                <p>{"EH{wtf???how_u_G3T_h3re???}"}</p>
            </div>

            <p class="timer-text">系統即將自我毀滅（並傳送你離開），倒數 <span id="countdown">3</span> 秒...</p>
        </div>
    </main>

    <script is:inline>
        let seconds = 3;
        const countdownEl = document.getElementById('countdown');

        const interval = setInterval(() => {
            seconds--;
            if (countdownEl) countdownEl.innerText = seconds;

            if (seconds <= 0) {
                clearInterval(interval);
                // 執行 Rickroll 傳送術
                window.location.href = 'https://www.youtube.com/watch?v=dQw4w9WgXcQ';
            }
        }, 1000);
    </script>
</body>
</html>

<style>
    /* 專屬於這個惡作劇頁面的極簡終端機風格 */
    .terminal-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        text-align: center;
    }

    .terminal-box {
        border: 1px solid #ff3333;
        padding: 3rem 2rem;
        border-radius: 8px;
        background-color: #0a0a0a;
        box-shadow: 0 0 30px rgba(255, 51, 51, 0.15);
        max-width: 500px;
        width: 100%;
    }

    .warning-text {
        color: #ff3333 !important;
        font-family: monospace;
        font-size: 1.8rem;
        margin-bottom: 1rem;
        letter-spacing: 2px;
    }

    .hint {
        color: var(--text-muted);
        font-size: 0.95rem;
    }

    .flag-box {
        background: #111;
        border: 1px dashed var(--border-color);
        padding: 1rem;
        margin: 2rem 0;
        border-radius: 4px;
    }

    .flag-box code {
        color: #00ff00 !important; /* 駭客綠 Flag */
        font-family: monospace;
        font-size: 1rem;
    }

    .timer-text {
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    #countdown {
        color: rgb(var(--accent));
        font-weight: bold;
        font-size: 1.2rem;
    }
</style>